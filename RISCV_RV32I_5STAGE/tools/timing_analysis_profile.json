{
  "clock_port": "iClk",
  "reset_port": "iRstn",
  "clock_period_ns": 10.0,
  "analysis_mode": "pipeline_perf",
  "default_output_root": ".analysis/pipeline_perf",
  "default_report_path": "PIPELINE_PERF_REPORT.md",
  "integrated_report_path": "md/INTEGRATED_TIMING_REPORT.md",
  "compare_single_cycle_project": "RISCV_RV32I_SINGLE",
  "focus_analysis": {
    "enabled": true,
    "output_subdir": "instruction_focus",
    "instruction_mem_relpath": "src/InstructionFORTIMING.mem",
    "rom_param_path": "uInstrRom.P_INIT_FILE",
    "wrapper_module_prefix": "TimingFocusTop_",
    "wrapper_instance_name": "uDesign",
    "emit_class_focus": true,
    "emit_mnemonic_focus": true
  },
  "stage_order": [
    "IF",
    "ID",
    "EX",
    "MEM",
    "WB",
    "CF"
  ],
  "probe_families": [
    {
      "key": "if_boundary",
      "label": "IF / IF-ID Boundary",
      "description": "Instruction fetch and front-end control timing into the IF/ID pipeline register.",
      "artifact_key": "if_boundary",
      "stage": "IF",
      "instance_patterns": [
        "*uIfIdReg*"
      ],
      "ref_name_patterns": [
        "IfIdReg"
      ],
      "pin_name_patterns": [
        "D"
      ]
    },
    {
      "key": "id_boundary",
      "label": "ID / ID-EX Boundary",
      "description": "Decode, control, and operand timing into the ID/EX pipeline register.",
      "artifact_key": "id_boundary",
      "stage": "ID",
      "instance_patterns": [
        "*uIdExReg*"
      ],
      "ref_name_patterns": [
        "IdExReg"
      ],
      "pin_name_patterns": [
        "D"
      ]
    },
    {
      "key": "ex_boundary",
      "label": "EX / EX-MEM Boundary",
      "description": "Execute-stage ALU, branch, and redirect timing into the EX/MEM pipeline register.",
      "artifact_key": "ex_boundary",
      "stage": "EX",
      "instance_patterns": [
        "*uExMemReg*"
      ],
      "ref_name_patterns": [
        "ExMemReg"
      ],
      "pin_name_patterns": [
        "D"
      ]
    },
    {
      "key": "mem_boundary",
      "label": "MEM / MEM-WB Boundary",
      "description": "Memory return and writeback-payload timing into the MEM/WB pipeline register.",
      "artifact_key": "mem_boundary",
      "stage": "MEM",
      "instance_patterns": [
        "*uMemWbReg*"
      ],
      "ref_name_patterns": [
        "MemWbReg"
      ],
      "pin_name_patterns": [
        "D"
      ]
    },
    {
      "key": "wb_retire",
      "label": "WB / Retire Sink",
      "description": "Final writeback and retire timing into the retained timing sink register.",
      "artifact_key": "wb_retire",
      "stage": "WB",
      "instance_patterns": [
        "*TimingSinkReg*"
      ],
      "endpoint_patterns": [
        "*TimingSinkReg*"
      ],
      "pin_name_patterns": [
        "D"
      ]
    },
    {
      "key": "pc_feedback",
      "label": "CF / Next-PC Redirect",
      "description": "Branch, jump, trap, interrupt, and next-PC timing into the fetch-stage program-counter register.",
      "artifact_key": "pc_feedback",
      "stage": "CF",
      "instance_patterns": [
        "*uFetchStage/uPc*",
        "*uPc*"
      ],
      "ref_name_patterns": [
        "Pc"
      ],
      "endpoint_patterns": [
        "*uFetchStage/uPc/*/D",
        "*uPc/*/D"
      ],
      "pin_name_patterns": [
        "D"
      ]
    }
  ],
  "stage_boundaries": [
    {
      "key": "stage_if",
      "label": "IF Stage (PC -> IF/ID)",
      "description": "Register-to-register timing from the program counter into the IF/ID pipeline register.",
      "artifact_key": "stage_if",
      "stage": "IF",
      "from": {
        "instance_patterns": [
          "*uFetchStage/uPc*"
        ],
        "ref_name_patterns": [
          "Pc"
        ],
        "pin_name_patterns": [
          "C"
        ]
      },
      "to": {
        "instance_patterns": [
          "*uIfIdReg*"
        ],
        "ref_name_patterns": [
          "IfIdReg"
        ],
        "pin_name_patterns": [
          "D"
        ]
      }
    },
    {
      "key": "stage_id",
      "label": "ID Stage (IF/ID -> ID/EX)",
      "description": "Register-to-register timing from the IF/ID pipeline register into the ID/EX pipeline register.",
      "artifact_key": "stage_id",
      "stage": "ID",
      "from": {
        "instance_patterns": [
          "*uIfIdReg*"
        ],
        "ref_name_patterns": [
          "IfIdReg"
        ],
        "pin_name_patterns": [
          "C"
        ]
      },
      "to": {
        "instance_patterns": [
          "*uIdExReg*"
        ],
        "ref_name_patterns": [
          "IdExReg"
        ],
        "pin_name_patterns": [
          "D"
        ]
      }
    },
    {
      "key": "stage_ex",
      "label": "EX Stage (ID/EX -> EX/MEM)",
      "description": "Register-to-register timing from the ID/EX pipeline register into the EX/MEM pipeline register.",
      "artifact_key": "stage_ex",
      "stage": "EX",
      "from": {
        "instance_patterns": [
          "*uIdExReg*"
        ],
        "ref_name_patterns": [
          "IdExReg"
        ],
        "pin_name_patterns": [
          "C"
        ]
      },
      "to": {
        "instance_patterns": [
          "*uExMemReg*"
        ],
        "ref_name_patterns": [
          "ExMemReg"
        ],
        "pin_name_patterns": [
          "D"
        ]
      }
    },
    {
      "key": "stage_mem",
      "label": "MEM Stage (EX/MEM -> MEM/WB)",
      "description": "Register-to-register timing from the EX/MEM pipeline register into the MEM/WB pipeline register.",
      "artifact_key": "stage_mem",
      "stage": "MEM",
      "from": {
        "instance_patterns": [
          "*uExMemReg*"
        ],
        "ref_name_patterns": [
          "ExMemReg"
        ],
        "pin_name_patterns": [
          "C"
        ]
      },
      "to": {
        "instance_patterns": [
          "*uMemWbReg*"
        ],
        "ref_name_patterns": [
          "MemWbReg"
        ],
        "pin_name_patterns": [
          "D"
        ]
      }
    },
    {
      "key": "stage_wb",
      "label": "WB Stage (MEM/WB -> Retire Sink)",
      "description": "Register-to-register timing from the MEM/WB pipeline register into the retained retire timing sink.",
      "artifact_key": "stage_wb",
      "stage": "WB",
      "from": {
        "instance_patterns": [
          "*uMemWbReg*"
        ],
        "ref_name_patterns": [
          "MemWbReg"
        ],
        "pin_name_patterns": [
          "C"
        ]
      },
      "to": {
        "instance_patterns": [
          "*TimingSinkReg*"
        ],
        "endpoint_patterns": [
          "*TimingSinkReg*"
        ],
        "pin_name_patterns": [
          "D"
        ]
      }
    }
  ],
