{
  "clock_port": "iClk",
  "reset_port": "iRstn",
  "clock_period_ns": 10.0,
  "analysis_mode": "single_cycle",
  "default_output_dir": ".analysis/single_cycle_perf",
  "default_report_path": "SINGLE_CYCLE_OPTIMIZATION_REPORT.md",
  "probe_families": [
    {
      "key": "timing_metric",
      "label": "Timing Metric",
      "description": "Top-level retained writeback-derived timing sink",
      "artifact_key": "timing_metric",
      "endpoint_patterns": [
        "*timingRetainMetric_reg*"
      ],
      "artifact_aliases": [
        "timing_metric"
      ],
      "end_match_tokens": [
        "timingRetainMetric"
      ]
    }
  ],
  "legacy_probe_families": [
    {
      "key": "pc_feedback",
      "label": "PC Feedback",
      "description": "Retained PC enable and next-PC sink family",
      "artifact_key": "pc_feedback",
      "artifact_aliases": [
        "pc_feedback"
      ],
      "end_match_tokens": [
        "timingRetainPcFeedback"
      ]
    },
    {
      "key": "load_writeback",
      "label": "Load Writeback",
      "description": "Retained load writeback sink family",
      "artifact_key": "load_writeback",
      "artifact_aliases": [
        "load_writeback"
      ],
      "end_match_tokens": [
        "timingRetainLoadWb"
      ]
    },
    {
      "key": "alu_writeback",
      "label": "ALU Writeback",
      "description": "Retained ALU writeback sink family",
      "artifact_key": "alu_writeback",
      "artifact_aliases": [
        "alu_writeback"
      ],
      "end_match_tokens": [
        "timingRetainAluWb"
      ]
    },
    {
      "key": "branch_target",
      "label": "Branch Target",
      "description": "Retained conditional-branch target sink family",
      "artifact_key": "branch_target",
      "artifact_aliases": [
        "branch_target",
        "branch_jalr"
      ],
      "end_match_tokens": [
        "timingRetainBranchTarget"
      ]
    },
    {
      "key": "jump_target",
      "label": "Jump Target",
      "description": "Retained JAL target sink family",
      "artifact_key": "jump_target",
      "artifact_aliases": [
        "jump_target"
      ],
      "end_match_tokens": [
        "timingRetainJumpTarget"
      ]
    },
    {
      "key": "jalr_target",
      "label": "JALR Target",
      "description": "Retained JALR target sink family",
      "artifact_key": "jalr_target",
      "artifact_aliases": [
        "jalr_target",
        "branch_jalr"
      ],
      "end_match_tokens": [
        "timingRetainJalrTarget"
      ]
    }
  ],
